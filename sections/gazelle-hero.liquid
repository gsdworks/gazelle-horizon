{% comment %}
  Section: gazelle-hero.liquid
  Display name: "Gazelle Hero"

  Full-width slideshow. Slides are optionally clickable and swipeable.

  16 July:
  1. Slides accept an optional link (block.settings.url) — wraps the media in <a>.
  2. Mobile image is OPTIONAL and falls back to the desktop image, keyed to a
     per-slide `has-mobile` class. Previously the desktop image was hidden on mobile
     unconditionally, so a slide with no mobile image rendered BLANK.
  3. Adjacent-slide bleed fixed. `overflow: hidden` clips to the PADDING box, not the
     content box — so the 20px horizontal padding on .gazelle-hero was a window the
     neighbouring slides showed through. Clipping now happens on
     .gazelle-hero__viewport, which carries no padding.
  4. Swipe / drag (Pointer Events — one path for mouse, touch and trackpad), with
     axis-locking, `touch-action: pan-y`, rubber-band at the ends, and capture-phase
     click suppression so dragging a linked slide doesn't navigate.

  5. NATIVE COLOUR SCHEME (`color_scheme` → `color-{{ scheme }}` class).
     ⚠️ STRUCTURE CHANGED to make this work: .gazelle-hero was the max-width:1200px
     element, so a background on it would only paint the centre column, not the full
     band. Split into an outer full-bleed .gazelle-hero (carries the scheme class and
     the background) and an inner .gazelle-hero__inner (max-width 1200px + gutter).

     HONEST NOTE: a scheme does less here than elsewhere — the artwork covers most of
     the band, so it only tints the 20px gutter and the dots row. Added for
     consistency with the other sections at Grant's call, not because it's dramatic.

     Dots were hardcoded #ccc / #222 and would have vanished on Scheme 5 Charcoal.
     They now use `currentColor` + opacity, which the scheme class drives.

  6. CSS scoped to #gazelle-hero-{{ section.id }} and moved into {% raw %}{% style %}{% endraw %}, matching
     gazelle-focus and gazelle-categories. Lets a second hero instance be styled
     independently and follows the repo convention.
{% endcomment %}

<div
  class="gazelle-hero color-{{ section.settings.color_scheme }}"
  id="gazelle-hero-{{ section.id }}"
>
  <div class="gazelle-hero__inner">
    <div class="gazelle-hero__viewport" id="gazelle-hero-viewport-{{ section.id }}">
      <div class="gazelle-hero__track" id="gazelle-hero-track-{{ section.id }}">
        {% for block in section.blocks %}
          <div
            class="gazelle-hero__slide{% if block.settings.mobile_image != blank %} has-mobile{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- liquid
              assign has_link = false
              if block.settings.url != blank
                assign has_link = true
              endif
            -%}

            {% if has_link %}<a class="gazelle-hero__link" href="{{ block.settings.url }}">{% endif %}

              {% if block.settings.desktop_image != blank %}
                <img
                  class="desktop-image"
                  src="{{ block.settings.desktop_image | image_url: width: 1200 }}"
                  alt="{{ block.settings.desktop_image.alt | escape }}"
                  width="{{ block.settings.desktop_image.width }}"
                  height="{{ block.settings.desktop_image.height }}"
                  draggable="false"
                  {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                >
              {% else %}
                <div class="gazelle-hero__placeholder">
                  <span>Add a desktop image in the theme editor</span>
                </div>
              {% endif %}

              {% if block.settings.mobile_image != blank %}
                <img
                  class="mobile-image"
                  src="{{ block.settings.mobile_image | image_url: width: 800 }}"
                  alt="{{ block.settings.mobile_image.alt | escape }}"
                  width="{{ block.settings.mobile_image.width }}"
                  height="{{ block.settings.mobile_image.height }}"
                  draggable="false"
                  loading="lazy"
                >
              {% endif %}

            {% if has_link %}</a>{% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    {% if section.blocks.size > 1 %}
      <div class="gazelle-hero__dots" id="gazelle-hero-dots-{{ section.id }}">
        {% for block in section.blocks %}
          <button
            class="gazelle-hero__dot {% if forloop.first %}is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
            type="button"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% style %}
  /* Outer band: full-bleed so the colour scheme paints edge to edge.
     The scheme class supplies background-color AND color; the dots below lean on
     `currentColor` so they follow whichever scheme is picked. */
  #gazelle-hero-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  /* Clipping lives here, NOT on the padded element.
     overflow clips to the padding box — putting it on a padded element lets
     adjacent slides show through the padding strips. This element has no padding. */
  #gazelle-hero-{{ section.id }} .gazelle-hero__viewport {
    overflow: hidden;
    cursor: grab;
    /* Allow vertical page scroll, capture horizontal for the slider. */
    touch-action: pan-y;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__viewport.is-dragging {
    cursor: grabbing;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__track {
    display: flex;
    transition: transform 0.6s ease;
  }

  /* Killed during a drag so the slide tracks the finger 1:1. */
  #gazelle-hero-{{ section.id }} .gazelle-hero__track.is-dragging {
    transition: none;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__slide {
    min-width: 100%;
    position: relative;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__link {
    display: block;
    -webkit-user-drag: none;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__slide img {
    width: 100%;
    height: auto;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__slide .mobile-image {
    display: none;
  }

  /* Empty-block placeholder, tinted from the scheme rather than a fixed grey. */
  #gazelle-hero-{{ section.id }} .gazelle-hero__placeholder {
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, currentColor 8%, transparent);
    color: color-mix(in srgb, currentColor 55%, transparent);
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 16px 0 8px;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    /* currentColor + opacity, so dots read on Paper AND Charcoal. */
    background: currentColor;
    opacity: 0.28;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  #gazelle-hero-{{ section.id }} .gazelle-hero__dot.is-active {
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    /* Only swap to the mobile image on slides that HAVE one.
       Slides without a mobile image keep showing the desktop image (scaled). */
    #gazelle-hero-{{ section.id }} .gazelle-hero__slide.has-mobile .desktop-image {
      display: none;
    }
    #gazelle-hero-{{ section.id }} .gazelle-hero__slide.has-mobile .mobile-image {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #gazelle-hero-{{ section.id }} .gazelle-hero__track {
      transition: none;
    }
  }
{% endstyle %}

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var hero = document.getElementById('gazelle-hero-' + sectionId);
    var viewport = document.getElementById('gazelle-hero-viewport-' + sectionId);
    var track = document.getElementById('gazelle-hero-track-' + sectionId);
    var dotsContainer = document.getElementById('gazelle-hero-dots-' + sectionId);
    var dots = dotsContainer ? dotsContainer.querySelectorAll('.gazelle-hero__dot') : [];
    var totalSlides = {{ section.blocks.size }};
    var currentIndex = 0;
    var autoplayDelay = {{ section.settings.autoplay_speed | times: 1000 }};
    var autoplayTimer;

    // Fraction of slide width that must be dragged to advance. 0.15 = 15%.
    var SWIPE_FRACTION = 0.15;
    // Movement beyond this (px) counts as a drag, not a tap — used to swallow link clicks.
    var DRAG_CLICK_THRESHOLD = 8;

    var isDragging = false;
    var hasDragged = false;
    var startX = 0;
    var startY = 0;
    var deltaX = 0;
    var lockedAxis = null; // 'x' | 'y' | null

    function goToSlide(index) {
      currentIndex = index;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function nextSlide() {
      goToSlide((currentIndex + 1) % totalSlides);
    }

    function startAutoplay() {
      if (totalSlides > 1) {
        stopAutoplay();
        autoplayTimer = setInterval(nextSlide, autoplayDelay);
      }
    }

    function stopAutoplay() {
      clearInterval(autoplayTimer);
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        stopAutoplay();
        goToSlide(parseInt(this.dataset.index, 10));
        startAutoplay();
      });
    });

    hero.addEventListener('mouseenter', stopAutoplay);
    hero.addEventListener('mouseleave', startAutoplay);

    // ---- Drag / swipe ----

    if (totalSlides > 1) {

      viewport.addEventListener('pointerdown', function(e) {
        // Ignore right-click / middle-click.
        if (e.button && e.button !== 0) return;
        isDragging = true;
        hasDragged = false;
        lockedAxis = null;
        startX = e.clientX;
        startY = e.clientY;
        deltaX = 0;
        stopAutoplay();
        track.classList.add('is-dragging');
        viewport.classList.add('is-dragging');
      });

      viewport.addEventListener('pointermove', function(e) {
        if (!isDragging) return;

        var dx = e.clientX - startX;
        var dy = e.clientY - startY;

        // Decide once whether this gesture is horizontal or vertical.
        // If vertical, bail out so the page can scroll normally.
        if (lockedAxis === null) {
          if (Math.abs(dx) < 5 && Math.abs(dy) < 5) return;
          lockedAxis = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
          if (lockedAxis === 'y') {
            isDragging = false;
            track.classList.remove('is-dragging');
            viewport.classList.remove('is-dragging');
            goToSlide(currentIndex);
            startAutoplay();
            return;
          }
          // Now we own the gesture.
          viewport.setPointerCapture(e.pointerId);
        }

        if (Math.abs(dx) > DRAG_CLICK_THRESHOLD) hasDragged = true;

        // Resist dragging past the first / last slide.
        if ((currentIndex === 0 && dx > 0) || (currentIndex === totalSlides - 1 && dx < 0)) {
          dx = dx * 0.25;
        }

        deltaX = dx;
        track.style.transform = 'translateX(calc(-' + (currentIndex * 100) + '% + ' + dx + 'px))';
      });

      function endDrag(e) {
        if (!isDragging) return;
        isDragging = false;
        track.classList.remove('is-dragging');
        viewport.classList.remove('is-dragging');

        if (viewport.hasPointerCapture && e.pointerId !== undefined) {
          try { viewport.releasePointerCapture(e.pointerId); } catch (err) {}
        }

        var threshold = viewport.offsetWidth * SWIPE_FRACTION;
        var target = currentIndex;

        if (deltaX < -threshold && currentIndex < totalSlides - 1) {
          target = currentIndex + 1;
        } else if (deltaX > threshold && currentIndex > 0) {
          target = currentIndex - 1;
        }

        goToSlide(target);
        deltaX = 0;
        startAutoplay();
      }

      viewport.addEventListener('pointerup', endDrag);
      viewport.addEventListener('pointercancel', endDrag);
      viewport.addEventListener('pointerleave', endDrag);

      // Swallow the click that follows a drag, so dragging a linked slide
      // doesn't navigate. Capture phase, so it fires before the <a>.
      viewport.addEventListener('click', function(e) {
        if (hasDragged) {
          e.preventDefault();
          e.stopPropagation();
          hasDragged = false;
        }
      }, true);

      // Keyboard: arrow keys when the slider has focus.
      viewport.setAttribute('tabindex', '0');
      viewport.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft' && currentIndex > 0) {
          stopAutoplay();
          goToSlide(currentIndex - 1);
          startAutoplay();
        } else if (e.key === 'ArrowRight' && currentIndex < totalSlides - 1) {
          stopAutoplay();
          goToSlide(currentIndex + 1);
          startAutoplay();
        }
      });
    }

    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Gazelle Hero",
  "tag": "section",
  "class": "gazelle-hero-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1",
      "info": "Sets the band background and the dot colours. The artwork covers most of the band, so this mainly affects the gutter and dots."
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (optional)",
          "info": "Recommended 800 x 367px. If empty, the desktop image is used on mobile."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)",
          "info": "Where the slide goes when clicked. Leave empty for a non-clickable slide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gazelle Hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
