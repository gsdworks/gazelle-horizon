{% comment %}
  Gazelle Hero Slideshow

  Fixes 16 July:
  1. Slides now accept an optional link (block.settings.url) — wraps the media in <a>.
  2. Mobile image is now OPTIONAL and falls back to the desktop image. The desktop
     image is only hidden on mobile when that slide actually HAS a mobile image
     (per-slide `has-mobile` class). Previously the desktop image was hidden on
     mobile unconditionally, so a slide with no mobile image rendered BLANK.
  3. Adjacent-slide bleed fixed. `overflow: hidden` clips to the PADDING box, not
     the content box — so the 20px horizontal padding on .gazelle-hero was a window
     the neighbouring slides showed through. Clipping now happens on a separate
     inner .gazelle-hero__viewport which carries no padding.
{% endcomment %}

<style>
  .gazelle-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  /* Clipping lives here, NOT on .gazelle-hero.
     overflow clips to the padding box — putting it on a padded element lets
     adjacent slides show through the padding strips. This element has no padding. */
  .gazelle-hero__viewport {
    overflow: hidden;
  }

  .gazelle-hero__track {
    display: flex;
    transition: transform 0.6s ease;
  }

  .gazelle-hero__slide {
    min-width: 100%;
    position: relative;
  }

  .gazelle-hero__link {
    display: block;
  }

  .gazelle-hero__slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gazelle-hero__slide .mobile-image {
    display: none;
  }

  .gazelle-hero__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 16px 0 8px;
  }

  .gazelle-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease;
  }

  .gazelle-hero__dot.is-active {
    background: #222;
  }

  @media screen and (max-width: 768px) {
    /* Only swap to the mobile image on slides that HAVE one.
       Slides without a mobile image keep showing the desktop image (scaled). */
    .gazelle-hero__slide.has-mobile .desktop-image {
      display: none;
    }
    .gazelle-hero__slide.has-mobile .mobile-image {
      display: block;
    }
  }
</style>

<div class="gazelle-hero" id="gazelle-hero-{{ section.id }}">
  <div class="gazelle-hero__viewport">
    <div class="gazelle-hero__track" id="gazelle-hero-track-{{ section.id }}">
      {% for block in section.blocks %}
        <div
          class="gazelle-hero__slide{% if block.settings.mobile_image != blank %} has-mobile{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- liquid
            assign has_link = false
            if block.settings.url != blank
              assign has_link = true
            endif
          -%}

          {% if has_link %}<a class="gazelle-hero__link" href="{{ block.settings.url }}">{% endif %}

            {% if block.settings.desktop_image != blank %}
              <img
                class="desktop-image"
                src="{{ block.settings.desktop_image | image_url: width: 1200 }}"
                alt="{{ block.settings.desktop_image.alt | escape }}"
                width="{{ block.settings.desktop_image.width }}"
                height="{{ block.settings.desktop_image.height }}"
                {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
              >
            {% else %}
              <div style="background:#f0f0f0; height: 400px; display:flex; align-items:center; justify-content:center;">
                <span style="color:#999;">Add a desktop image in the theme editor</span>
              </div>
            {% endif %}

            {% if block.settings.mobile_image != blank %}
              <img
                class="mobile-image"
                src="{{ block.settings.mobile_image | image_url: width: 800 }}"
                alt="{{ block.settings.mobile_image.alt | escape }}"
                width="{{ block.settings.mobile_image.width }}"
                height="{{ block.settings.mobile_image.height }}"
                loading="lazy"
              >
            {% endif %}

          {% if has_link %}</a>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.blocks.size > 1 %}
    <div class="gazelle-hero__dots" id="gazelle-hero-dots-{{ section.id }}">
      {% for block in section.blocks %}
        <button
          class="gazelle-hero__dot {% if forloop.first %}is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var hero = document.getElementById('gazelle-hero-' + sectionId);
    var track = document.getElementById('gazelle-hero-track-' + sectionId);
    var dotsContainer = document.getElementById('gazelle-hero-dots-' + sectionId);
    var dots = dotsContainer ? dotsContainer.querySelectorAll('.gazelle-hero__dot') : [];
    var totalSlides = {{ section.blocks.size }};
    var currentIndex = 0;
    var autoplayDelay = {{ section.settings.autoplay_speed | times: 1000 }};
    var autoplayTimer;

    function goToSlide(index) {
      currentIndex = index;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function nextSlide() {
      goToSlide((currentIndex + 1) % totalSlides);
    }

    function startAutoplay() {
      if (totalSlides > 1) {
        autoplayTimer = setInterval(nextSlide, autoplayDelay);
      }
    }

    function stopAutoplay() {
      clearInterval(autoplayTimer);
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        stopAutoplay();
        goToSlide(parseInt(this.dataset.index));
        startAutoplay();
      });
    });

    hero.addEventListener('mouseenter', stopAutoplay);
    hero.addEventListener('mouseleave', startAutoplay);

    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Gazelle Hero",
  "tag": "section",
  "class": "gazelle-hero-section",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (optional)",
          "info": "Recommended 800 x 367px. If empty, the desktop image is used on mobile."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)",
          "info": "Where the slide goes when clicked. Leave empty for a non-clickable slide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gazelle Hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
