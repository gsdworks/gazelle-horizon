{% comment %}
  Section: gazelle-categories.liquid
  Display name: "Icon Row"

  A row of circular icon links. Reusable — add it more than once per page with
  different content (e.g. one instance for browse categories, one for publisher
  highlights). Each instance holds its own blocks and settings.

  ⚠️ FILENAME: stays `gazelle-categories.liquid` deliberately. The section `type`
  in templates/index.json is `gazelle-categories`; renaming the file would orphan
  the live section. Only the schema display name changed (16 July).

  16 July changes:
  - Renamed "Category Icons" → "Icon Row" (no longer category-specific).
  - Icons can be IMAGES (PNG/SVG) as well as emoji. Image wins when set; emoji is
    the fallback. Per-block, so instances can mix.
  - Image fills the circle (object-fit: cover), clipped by border-radius +
    overflow:hidden, so artwork with square/white corners still reads as a circle.
  - CSS scoped to #gazelle-icon-row-{{ section.id }} so two instances on one page
    can be styled independently without a selector collision.
  - Heading default blank; preset lean (3 blocks); max_blocks 16.
  - Separate desktop + mobile icon size, both section-level (every icon in a row
    scales together — deliberately no per-block size). Both feed --gz-icon-size,
    redeclared inside the media query. Gap, item width and emoji size all derive
    from it. NOTE: deliberately NO "columns per row" setting — size + wrap gives the
    per-row count implicitly (260px → 4 across in 1200px) and cannot overflow.

  - NATIVE COLOUR SCHEME (`color_scheme` → `color-{{ scheme }}` class).
    ⚠️ Replaces a hardcoded `background: #ffffff`, which is why this row rendered as
    a white band against the Paper page and could never sit on Scheme 5 Charcoal.

    ⚠️ The circle plate and label colours were also hardcoded (#eef0f3 plate,
    #dde0e6 hover, #1a1a1a label) and would have been invisible or wrong on a dark
    scheme. They now derive from the scheme:
      - plate/hover use color-mix() against `currentColor`, so they're a tint of the
        scheme's own foreground rather than a fixed grey.
      - labels inherit `color` from the scheme class.
    Verified against the repo: Horizon 3.4 exposes --color-background,
    --color-foreground and --color-border in assets/base.css. currentColor is used
    in preference anyway — it needs no variable name at all.

    Image blocks keep a TRANSPARENT plate (the artwork IS the circle); only emoji
    blocks show the tint.
{% endcomment %}

{%- liquid
  assign icon_size = section.settings.icon_size | default: 90
  assign icon_size_mobile = section.settings.icon_size_mobile | default: 72
-%}

<section
  class="gazelle-icon-row color-{{ section.settings.color_scheme }}"
  id="gazelle-icon-row-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="gazelle-icon-row__inner">

    {% if section.settings.heading != blank %}
      <h2 class="gazelle-icon-row__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gazelle-icon-row__grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <a
            class="gazelle-icon-row__item"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            <div class="gazelle-icon-row__circle{% if block.settings.image != blank %} has-image{% endif %}">
              {% if block.settings.image != blank %}
                <img
                  class="gazelle-icon-row__image"
                  src="{{ block.settings.image | image_url: width: 560 }}"
                  alt=""
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                >
              {% else %}
                <span class="gazelle-icon-row__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
              {% endif %}
            </div>
            {% if block.settings.label != blank %}
              <span class="gazelle-icon-row__label">{{ block.settings.label }}</span>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% style %}
  #gazelle-icon-row-{{ section.id }} {
    /* Single source of truth for this instance's sizing (desktop). */
    --gz-icon-size: {{ icon_size }}px;
    /* Background + foreground come from the colour scheme class — no hardcoded
       #ffffff. Everything below leans on currentColor so the chrome follows it. */
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__heading {
    text-align: center;
    font-size: 1.75rem;
    font-style: italic;
    font-weight: 400;
    color: inherit;           /* follows the scheme */
    margin: 0 0 40px;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    /* Gap scales with the circle so big icons don't crowd. */
    gap: clamp(16px, calc(var(--gz-icon-size) * 0.3), 48px)
         clamp(16px, calc(var(--gz-icon-size) * 0.25), 40px);
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    /* Track the circle, but never so narrow that a short label cramps. */
    width: max(var(--gz-icon-size), 88px);
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle {
    width: var(--gz-icon-size);
    height: var(--gz-icon-size);
    border-radius: 50%;
    /* A tint of the scheme's own foreground, not a fixed grey. */
    background: color-mix(in srgb, currentColor 8%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    /* Clips image artwork to the circle regardless of the source file's corners. */
    overflow: hidden;
    flex: 0 0 auto;
  }

  /* The artwork is the circle — no plate behind it. */
  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle.has-image {
    background: transparent;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle {
    background: color-mix(in srgb, currentColor 16%, transparent);
    transform: scale(1.07);
  }

  /* Keep image blocks from flashing a plate on hover. */
  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle.has-image {
    background: transparent;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 50%;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__emoji {
    /* Scale the emoji with the circle. */
    font-size: calc(var(--gz-icon-size) * 0.35);
    line-height: 1;
    display: block;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__label {
    font-size: 0.875rem;
    text-align: center;
    font-weight: 500;
    color: inherit;           /* follows the scheme */
    line-height: 1.3;
  }

  @media (prefers-reduced-motion: reduce) {
    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle {
      transition: none;
    }
    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    #gazelle-icon-row-{{ section.id }} {
      /* Mobile size is its own control, not derived from the desktop value. */
      --gz-icon-size: {{ icon_size_mobile }}px;
      padding-left: 0;
      padding-right: 0;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__heading {
      padding: 0 16px;
      text-align: left;
      margin-bottom: 24px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid {
      display: flex;
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 16px;
      padding: 0 16px 12px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid::-webkit-scrollbar {
      display: none;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item {
      flex: 0 0 auto;
      width: max(var(--gz-icon-size), 80px);
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__label {
      font-size: 0.8rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Icon Row",
  "tag": "section",
  "class": "gazelle-icon-row-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional. Leave empty for no heading."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1",
      "info": "Sets the band background, the labels, and the circle plate behind emoji icons."
    },
    {
      "type": "header",
      "content": "Icon size"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Desktop",
      "min": 60,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 90,
      "info": "Circle diameter above 640px. Bigger icons fit fewer per row and the rest wrap — e.g. 260px gives 4 across."
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Mobile",
      "min": 48,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72,
      "info": "Circle diameter at 640px and below. The row scrolls sideways on mobile, so larger sizes show fewer icons at once."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image (optional)",
          "info": "Square image. Use at least 2x your icon size (e.g. 560px for a 280px circle) so it stays sharp on retina. If empty, the emoji below is used."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon (emoji)",
          "default": "📚",
          "info": "Only used when no icon image is set."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Optional. Leave empty when the artwork already carries the name."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Can link to a collection, page, or any URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Row",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ],
  "max_blocks": 16
}
{% endschema %}
