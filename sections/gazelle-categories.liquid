{% comment %}
  Section: gazelle-categories.liquid
  Display name: "Icon Row"

  A row of circular icon links. Reusable — add it more than once per page with
  different content (e.g. one instance for browse categories, one for publisher
  highlights). Each instance holds its own blocks and settings.

  ⚠️ FILENAME: stays `gazelle-categories.liquid` deliberately. The section `type`
  in templates/index.json is `gazelle-categories`; renaming the file would orphan
  the live section. Only the schema display name changed (16 July).

  16 July changes:
  - Renamed "Category Icons" → "Icon Row" (it is no longer category-specific).
  - Icons can be IMAGES (PNG/SVG) as well as emoji. Image wins when set; emoji is
    the fallback. Per-block, so instances can mix.
  - Image fills the circle (object-fit: cover) and is clipped by the circle's
    border-radius + overflow:hidden, so artwork with square or white corners still
    reads as a circle.
  - Grey placeholder plate is suppressed on image blocks (the artwork IS the circle);
    still shown behind emoji blocks.
  - CSS is now scoped to the section instance (#gazelle-icon-row-{{ section.id }}),
    so two instances on one page can be styled independently later without a
    selector collision.
  - Heading default is now blank and the preset is lean (3 blocks) — the old
    9-category preset presumed one use.
  - Links were already supported (block.settings.link) — unchanged.
{% endcomment %}

<section
  class="gazelle-icon-row"
  id="gazelle-icon-row-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="gazelle-icon-row__inner">

    {% if section.settings.heading != blank %}
      <h2 class="gazelle-icon-row__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gazelle-icon-row__grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <a
            class="gazelle-icon-row__item"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            <div class="gazelle-icon-row__circle{% if block.settings.image != blank %} has-image{% endif %}">
              {% if block.settings.image != blank %}
                <img
                  class="gazelle-icon-row__image"
                  src="{{ block.settings.image | image_url: width: 220 }}"
                  alt=""
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                >
              {% else %}
                <span class="gazelle-icon-row__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
              {% endif %}
            </div>
            <span class="gazelle-icon-row__label">{{ block.settings.label }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% style %}
  #gazelle-icon-row-{{ section.id }} {
    padding: 52px 24px;
    background: #ffffff;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__heading {
    text-align: center;
    font-size: 1.75rem;
    font-style: italic;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 40px;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px 20px;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    width: 100px;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #eef0f3;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    /* Clips image artwork to the circle regardless of the source file's corners. */
    overflow: hidden;
  }

  /* The artwork is the circle — no grey plate behind it. */
  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle.has-image {
    background: transparent;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle {
    background: #dde0e6;
    transform: scale(1.07);
  }

  /* Keep image blocks from flashing a grey plate on hover. */
  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle.has-image {
    background: transparent;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 50%;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__emoji {
    font-size: 2rem;
    line-height: 1;
    display: block;
  }

  #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__label {
    font-size: 0.875rem;
    text-align: center;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.3;
  }

  @media (prefers-reduced-motion: reduce) {
    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle {
      transition: none;
    }
    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item:hover .gazelle-icon-row__circle {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    #gazelle-icon-row-{{ section.id }} {
      padding: 36px 0;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__heading {
      padding: 0 16px;
      text-align: left;
      margin-bottom: 24px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid {
      display: flex;
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
      padding: 0 16px 12px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__grid::-webkit-scrollbar {
      display: none;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__item {
      flex: 0 0 auto;
      width: 88px;
      padding: 0 8px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__circle {
      width: 72px;
      height: 72px;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__emoji {
      font-size: 1.6rem;
    }

    #gazelle-icon-row-{{ section.id }} .gazelle-icon-row__label {
      font-size: 0.8rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Icon Row",
  "tag": "section",
  "class": "gazelle-icon-row-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional. Leave empty for no heading."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image (optional)",
          "info": "Square image, 220 x 220px or larger (400px for retina). Fills the circle and is clipped to it. If empty, the emoji below is used."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon (emoji)",
          "default": "📚",
          "info": "Only used when no icon image is set."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Can link to a collection, page, or any URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Row",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
