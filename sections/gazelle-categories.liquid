{% comment %}
  Section: gazelle-categories.liquid
  Circular icon/emoji grid linking to categories or collections
  Icons and links are fully configurable in the theme editor
{% endcomment %}

<section class="gazelle-categories" {{ section.shopify_attributes }}>
  <div class="gazelle-categories__inner">

    {% if section.settings.heading != blank %}
      <h2 class="gazelle-categories__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gazelle-categories__grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <a
            class="gazelle-categories__item"
            href="{{ block.settings.link }}"
            {{ block.shopify_attributes }}
          >
            <div class="gazelle-categories__circle">
              <span class="gazelle-categories__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
            </div>
            <span class="gazelle-categories__label">{{ block.settings.label }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .gazelle-categories {
    padding: 52px 24px;
    background: #ffffff;
  }

  .gazelle-categories__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .gazelle-categories__heading {
    text-align: center;
    font-size: 1.75rem;
    font-style: italic;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 40px;
  }

  .gazelle-categories__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px 20px;
  }

  .gazelle-categories__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    width: 100px;
  }

  .gazelle-categories__circle {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #eef0f3;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .gazelle-categories__item:hover .gazelle-categories__circle {
    background: #dde0e6;
    transform: scale(1.07);
  }

  .gazelle-categories__emoji {
    font-size: 2rem;
    line-height: 1;
    display: block;
  }

  .gazelle-categories__label {
    font-size: 0.875rem;
    text-align: center;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .gazelle-categories {
      padding: 36px 0;
    }

    .gazelle-categories__heading {
      padding: 0 16px;
      text-align: left;
      margin-bottom: 24px;
    }

    .gazelle-categories__grid {
      display: flex;
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
      padding: 0 16px 12px;
    }

    .gazelle-categories__grid::-webkit-scrollbar {
      display: none;
    }

    .gazelle-categories__item {
      flex: 0 0 auto;
      width: 88px;
      padding: 0 8px;
    }

    .gazelle-categories__circle {
      width: 72px;
      height: 72px;
    }

    .gazelle-categories__emoji {
      font-size: 1.6rem;
    }

    .gazelle-categories__label {
      font-size: 0.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Category Icons",
  "tag": "section",
  "class": "gazelle-categories-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You Might Be Looking For..."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon (emoji)",
          "default": "📚",
          "info": "Paste any emoji here to use as the icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Can link to a collection, page, or any URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Icons",
      "blocks": [
        { "type": "category", "settings": { "emoji": "⭐", "label": "Bestsellers" } },
        { "type": "category", "settings": { "emoji": "✨", "label": "New Books" } },
        { "type": "category", "settings": { "emoji": "🕐", "label": "Coming Soon" } },
        { "type": "category", "settings": { "emoji": "✒️", "label": "Signed" } },
        { "type": "category", "settings": { "emoji": "📖", "label": "Fiction" } },
        { "type": "category", "settings": { "emoji": "📰", "label": "Non-Fiction" } },
        { "type": "category", "settings": { "emoji": "👦", "label": "Children's" } },
        { "type": "category", "settings": { "emoji": "🎓", "label": "Teen & YA" } },
        { "type": "category", "settings": { "emoji": "🎁", "label": "Gifts" } }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
