{% comment %} Gazelle Thin Strip {% endcomment %}

<style>
  .gazelle-strip {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 20px;
  }

  .gazelle-strip img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gazelle-strip .mobile-image {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .gazelle-strip .desktop-image {
      display: none;
    }
    .gazelle-strip .mobile-image {
      display: block;
    }
  }
</style>

<div class="gazelle-strip">
  {% if section.settings.desktop_image != blank %}
    <img
      class="desktop-image"
      src="{{ section.settings.desktop_image | image_url: width: 1200 }}"
      alt="{{ section.settings.desktop_image.alt | escape }}"
      loading="lazy"
    >
  {% else %}
    <div style="background:#f0f0f0; height: 120px; display:flex; align-items:center; justify-content:center;">
      <span style="color:#999;">Add a desktop image in the theme editor</span>
    </div>
  {% endif %}

  {% if section.settings.mobile_image != blank %}
    <img
      class="mobile-image"
      src="{{ section.settings.mobile_image | image_url: width: 600 }}"
      alt="{{ section.settings.mobile_image.alt | escape }}"
      loading="lazy"
    >
  {% endif %}
</div>

{% schema %}
{
  "name": "Gazelle Strip",
  "tag": "section",
  "class": "gazelle-strip-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image (optional)"
    }
  ],
  "presets": [
    {
      "name": "Gazelle Strip"
    }
  ]
}
{% endschema %}
