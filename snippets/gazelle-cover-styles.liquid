{% comment %}
  Fixes single-cover product-page sizing to a consistent height with natural
  (per-cover) width, left-aligned, plus a light book-cover shadow and a crisp
  charcoal outline. Overrides Horizon's forced aspect-ratio: 1/1.25 and
  constrain-height cap (and its grid/flex stretch), which otherwise render
  portrait covers small/centred with empty space, or too tall.

  Everything is scoped to .product-information__media and gated on :only-child,
  so multi-image galleries (multiple sibling .product-media-container elements)
  keep native Horizon behaviour untouched. No !important — specificity alone
  (.product-information__media .product-media-container:only-child img = 0,3,1)
  beats base.css and the media-fit-cover rule.

  Render on the product template, e.g. {% render 'gazelle-cover-styles' %}.
{% endcomment %}

{% style %}
  /* Page width (1200px) is now set globally in snippets/gazelle-layout.liquid —
     the local --page-width override that used to live here has been removed. */

  .product-information__media .product-media-container:only-child {
    aspect-ratio: auto;                 /* kill the forced 1/1.25 */
    height: clamp(360px, 40vw, 475px);  /* consistent height, fluid, ~475px desktop */
    max-height: 475px;                  /* hard ceiling; overrides Horizon constrain-height */
    width: auto;                        /* natural width per cover, no distortion */
    max-width: 100%;
    margin-inline: 0;                   /* left-align (override Horizon auto-centring) */
    margin-inline-start: var(--gz-gutter, 24px); /* match the Synopsis band's inner gutter */
    margin-block-start: 24px;           /* align cover top with title (details block padding-block-start: 24) */
    align-self: start;                  /* stop stretching to fill the cell */
    justify-self: start;                /* stop stretching to fill the cell */
    overflow: visible;                  /* so the shadow isn't clipped */
  }

  /* Left-align the cover inside its container: overrides the theme's
     justify-content: center on the constrain-height constraint wrapper.
     .constrain-height is required so specificity (0,4,0) beats the theme's
     .product-media-container.constrain-height:has(...) rule (0,3,0). */
  .product-information__media .product-media-container.constrain-height:only-child {
    justify-content: flex-start;
  }

  .product-information__media .product-media-container:only-child img {
    aspect-ratio: auto;
    object-fit: contain;                /* never crop a cover; beats media-fit-cover */
    height: 100%;
    max-height: 475px;                  /* image itself can't exceed 475px */
    width: auto;
  }

  /* Border + shadow on the actual cover image. Explicit .product-media__image
     (0,4,0) is unambiguous and beats the theme's .product-media > * rule. */
  .product-information__media .product-media-container:only-child .product-media__image {
    border: 1px solid #1a1917;          /* crisp charcoal outline */
    border-radius: 2px;
    box-shadow: 0 4px 14px rgba(26, 25, 23, 0.1);
  }

  /* Stop the theme's overflow:hidden on the media wrappers (>=750px) from
     clipping the soft shadow. */
  .product-information__media .product-media-container:only-child .product-media,
  .product-information__media .product-media-container:only-child .product-media > * {
    overflow: visible;
  }

  /* Hero columns as a proportional centred pair (mockup: minmax(300px,1fr) 1.15fr):
     narrows the over-stretched 1fr cover column (killing the dead middle gap) and
     widens the buy box, instead of the native fixed 400px column pinned far right.
     Specificity (0,4,0) beats the native (0,3,0) rule; cover stays left-aligned. */
  @media screen and (min-width: 750px) {
    .product-information .product-information__grid.product-information--media-left:not(.product-information--media-none) {
      grid-template-columns: minmax(300px, 1fr) minmax(0, 1.15fr);
    }
  }

  /* Inset the buy box's right edge by the band's 24px gutter so it aligns with
     the Subjects/Classification card. margin (not padding): the details block
     emits an inline padding-inline-end:0 that would shadow a padding override. */
  @media screen and (min-width: 750px) {
    .product-information .product-details {
      margin-inline-end: var(--gz-gutter, 24px);
    }
  }
{% endstyle %}
